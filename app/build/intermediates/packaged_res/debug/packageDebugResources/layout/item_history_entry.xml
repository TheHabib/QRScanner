<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="horizontal"
    android:gravity="center_vertical"
    android:paddingStart="16dp"
    android:paddingEnd="8dp"
    android:paddingTop="12dp"
    android:paddingBottom="12dp"
    android:background="@color/card_bg">

    <!-- Type icon -->
    <ImageView
        android:id="@+id/ivHistoryIcon"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:padding="6dp"
        android:background="@drawable/icon_bg_circle"
        android:contentDescription="Type" />

    <!-- Text content -->
    <LinearLayout
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical"
        android:layout_marginStart="12dp"
        android:layout_marginEnd="8dp">

        <TextView
            android:id="@+id/tvHistoryTitle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/tvHistoryMeta"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#66FFFFFF"
            android:textSize="12sp"
            android:layout_marginTop="2dp" />

        <TextView
            android:id="@+id/tvHistoryContent"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:textColor="#CCFFFFFF"
            android:textSize="13sp"
            android:maxLines="3"
            android:ellipsize="end"
            android:layout_marginTop="4dp" />

    </LinearLayout>

    <!-- Star button -->
    <ImageButton
        android:id="@+id/btnHistoryStar"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="Favorite" />

    <!-- 3-dot menu -->
    <ImageButton
        android:id="@+id/btnHistoryMenu"
        android:layout_width="36dp"
        android:layout_height="36dp"
        android:src="@drawable/ic_more_vert"
        android:tint="#99FFFFFF"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="More options" />

</LinearLayout>
